# Ignore agent and local context files
.agents/
CONTEXT.MD

# Ignore archived legacy and runtime leftovers kept only for local reference
legacy/

# Ignore existing sample projects
job-app-website/
job-app-website.zip

# Ignore generated logs while keeping the directory in git
logs/*
!logs/.gitkeep
**/server.log
**/interaction_log.json
**/captured_data.json

# Ignore standard Python cache and virtual environments
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env

# Ignore Codex/local runtime artifacts
.codex_http_job_id.txt
.codex_ppt_server_pids.json
smoke_reports/

# Ignore presentation inspection scratch output
presentation_assets/downloads_deck_inspect/
presentation_assets/downloads_fixed_inspect/
presentation_assets/ppt_check/

# Ignore obsolete root-level exports from earlier iterations
/server.py
/finalize_setups.py
/SETUP_*.md
/*.html
/*.zip

# MacOS/Windows system files
.DS_Store
Thumbs.db
